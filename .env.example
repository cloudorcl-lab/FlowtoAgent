# ── LLM Provider Selection ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Which provider to use: claude | openai | gemini (default: claude)
LLM_PROVIDER=claude

# Shared token cap across all providers (default: 512)
LLM_MAX_TOKENS=512

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override model (default: claude-haiku-4-5)
# Options: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-6
ANTHROPIC_MODEL=claude-haiku-4-5

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Optional: override model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=...

# Optional: override model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
